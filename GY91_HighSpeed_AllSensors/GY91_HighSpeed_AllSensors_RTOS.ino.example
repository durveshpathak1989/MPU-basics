/*
  ============================================================
  GY91_HighSpeed_AllSensors_RTOS.ino
  Board: Adafruit HUZZAH32 Feather / ESP32
  Sensor module: GY-91 = MPU-9250 + BMP280

  This sketch uses the SAME existing library files:
    - GY91_MPU9250.h / GY91_MPU9250.cpp
    - GY91_BMP280.h  / GY91_BMP280.cpp

  How to use:
    1. Keep this file in the same folder as the library files above.
    2. Rename this file to .ino, or replace the existing polling .ino.
    3. Do NOT keep two .ino files with setup()/loop() in the same Arduino sketch folder.

  RTOS architecture:
    Core 1: IMU task      -> reads MPU-9250 accel/gyro/mag at 1 kHz target
    Core 1: BMP task      -> reads BMP280 at 50 Hz
    Core 0: Rate task     -> calculates read rates and jitter once per second
    Core 0: Telemetry task-> prints sensor snapshot at 10 Hz

  Jitter measurement:
    Jitter is measured as the difference between the actual task start-to-start
    interval and the expected interval.

      jitter_us = abs(actual_dt_us - expected_dt_us)

    Printed fields:
      avgDt = average observed start-to-start period
      minDt = minimum observed start-to-start period
      maxDt = maximum observed start-to-start period
      avgJ  = average absolute jitter
      maxJ  = maximum absolute jitter
      n     = number of timing samples in the last 1 second window

  Notes:
    - MPU-9250 uses SPI mode 3 inside GY91_MPU9250.cpp.
    - BMP280 uses SPI mode 0 inside GY91_BMP280.cpp.
    - Both devices share SCK/MOSI/MISO but use separate CS pins.
    - A mutex protects shared sensor data between tasks.
    - A second mutex protects the shared SPI bus between IMU and BMP tasks.
    - Serial printing is intentionally isolated from the IMU task.
  ============================================================
*/

#include <Arduino.h>
#include <SPI.h>
#include "GY91_MPU9250.h"
#include "GY91_BMP280.h"

// ============================================================
// HUZZAH32 Feather SPI pin map
// ============================================================
static const int PIN_SPI_SCK  = 5;
static const int PIN_SPI_MISO = 19;
static const int PIN_SPI_MOSI = 18;

static const int PIN_MPU_CS   = 33;
static const int PIN_BMP_CS   = 32;
static const int PIN_MPU_INT  = 27;   // optional, not used yet

// ============================================================
// Sensor objects using the existing libraries
// ============================================================
GY91_MPU9250 imu(PIN_MPU_CS, SPI);
GY91_BMP280  bmp(PIN_BMP_CS, SPI);

// ============================================================
// Timing configuration
// ============================================================
static const float SEA_LEVEL_HPA = 1013.25f;

static const uint32_t IMU_PERIOD_MS       = 1;     // 1 kHz target
static const uint32_t BMP_PERIOD_MS       = 20;    // 50 Hz
static const uint32_t TELEMETRY_PERIOD_MS = 100;   // 10 Hz
static const uint32_t RATE_PERIOD_MS      = 1000;  // 1 Hz rate/jitter calculation

static const uint32_t IMU_EXPECTED_US       = IMU_PERIOD_MS * 1000UL;
static const uint32_t BMP_EXPECTED_US       = BMP_PERIOD_MS * 1000UL;
static const uint32_t TELEMETRY_EXPECTED_US = TELEMETRY_PERIOD_MS * 1000UL;
static const uint32_t RATE_EXPECTED_US      = RATE_PERIOD_MS * 1000UL;

// ============================================================
// Jitter statistics
// ============================================================
struct TaskJitterStats {
    uint32_t expected_us;
    uint32_t last_start_us;

    // Live accumulation window
    uint32_t samples;
    uint32_t min_dt_us;
    uint32_t max_dt_us;
    uint32_t max_abs_jitter_us;
    uint64_t sum_dt_us;
    uint64_t sum_abs_jitter_us;

    // Reported once per second by taskRate
    uint32_t report_samples;
    uint32_t report_min_dt_us;
    uint32_t report_max_dt_us;
    uint32_t report_max_abs_jitter_us;
    float report_avg_dt_us;
    float report_avg_abs_jitter_us;
};

void resetJitterAccum(TaskJitterStats& s)
{
    s.samples = 0;
    s.min_dt_us = UINT32_MAX;
    s.max_dt_us = 0;
    s.max_abs_jitter_us = 0;
    s.sum_dt_us = 0;
    s.sum_abs_jitter_us = 0;
}

void initJitterStats(TaskJitterStats& s, uint32_t expected_us)
{
    memset(&s, 0, sizeof(TaskJitterStats));
    s.expected_us = expected_us;
    resetJitterAccum(s);
}

void recordJitter(TaskJitterStats& s, uint32_t now_us)
{
    if (s.last_start_us != 0) {
        uint32_t dt_us = (uint32_t)(now_us - s.last_start_us);
        uint32_t abs_jitter_us = (dt_us > s.expected_us) ?
                                 (dt_us - s.expected_us) :
                                 (s.expected_us - dt_us);

        s.samples++;
        if (dt_us < s.min_dt_us) s.min_dt_us = dt_us;
        if (dt_us > s.max_dt_us) s.max_dt_us = dt_us;
        if (abs_jitter_us > s.max_abs_jitter_us) s.max_abs_jitter_us = abs_jitter_us;
        s.sum_dt_us += dt_us;
        s.sum_abs_jitter_us += abs_jitter_us;
    }

    s.last_start_us = now_us;
}

void finalizeJitterStats(TaskJitterStats& s)
{
    if (s.samples > 0) {
        s.report_samples = s.samples;
        s.report_min_dt_us = s.min_dt_us;
        s.report_max_dt_us = s.max_dt_us;
        s.report_max_abs_jitter_us = s.max_abs_jitter_us;
        s.report_avg_dt_us = (float)s.sum_dt_us / (float)s.samples;
        s.report_avg_abs_jitter_us = (float)s.sum_abs_jitter_us / (float)s.samples;
    }

    resetJitterAccum(s);
}

// ============================================================
// Shared data between tasks
// ============================================================
struct SharedSensorData {
    GY91_IMUData imu;
    GY91_BMPData bmp;

    float imuHz;
    float bmpHz;
    float magHz;

    uint32_t imuReadCount;
    uint32_t bmpReadCount;
    uint32_t magNewCount;

    bool imuOk;
    bool bmpOk;

    TaskJitterStats imuJitter;
    TaskJitterStats bmpJitter;
    TaskJitterStats rateJitter;
    TaskJitterStats telemetryJitter;
};

SharedSensorData g_data;
SemaphoreHandle_t g_dataMutex = nullptr;
SemaphoreHandle_t g_spiMutex  = nullptr;

// ============================================================
// Task handles
// ============================================================
TaskHandle_t taskImuHandle       = nullptr;
TaskHandle_t taskBmpHandle       = nullptr;
TaskHandle_t taskTelemetryHandle = nullptr;
TaskHandle_t taskRateHandle      = nullptr;

// ============================================================
// Helper: record jitter safely
// ============================================================
void recordSharedJitter(TaskJitterStats SharedSensorData::*field, uint32_t now_us)
{
    if (xSemaphoreTake(g_dataMutex, pdMS_TO_TICKS(2)) == pdTRUE) {
        recordJitter(g_data.*field, now_us);
        xSemaphoreGive(g_dataMutex);
    }
}

// ============================================================
// Helper: copy IMU data into shared state
// ============================================================
void updateSharedImu(const GY91_IMUData& imuData)
{
    if (xSemaphoreTake(g_dataMutex, pdMS_TO_TICKS(2)) == pdTRUE) {
        g_data.imu = imuData;
        g_data.imuReadCount++;
        if (imuData.magNew) {
            g_data.magNewCount++;
        }
        g_data.imuOk = true;
        xSemaphoreGive(g_dataMutex);
    }
}

// ============================================================
// Helper: copy BMP data into shared state
// ============================================================
void updateSharedBmp(const GY91_BMPData& bmpData)
{
    if (xSemaphoreTake(g_dataMutex, pdMS_TO_TICKS(2)) == pdTRUE) {
        g_data.bmp = bmpData;
        g_data.bmpReadCount++;
        g_data.bmpOk = true;
        xSemaphoreGive(g_dataMutex);
    }
}

// ============================================================
// Task 1: IMU task
// Purpose:
//   Read MPU-9250 accel/gyro/temp and latest magnetometer value
//   at a 1 kHz target period.
// ============================================================
void taskImu(void* parameter)
{
    GY91_IMUData localImu;
    TickType_t lastWake = xTaskGetTickCount();

    while (true) {
        uint32_t startUs = micros();
        recordSharedJitter(&SharedSensorData::imuJitter, startUs);

        bool ok = false;
        if (xSemaphoreTake(g_spiMutex, pdMS_TO_TICKS(2)) == pdTRUE) {
            ok = imu.readAll(localImu);
            xSemaphoreGive(g_spiMutex);
        }

        if (ok) {
            updateSharedImu(localImu);
        }

        vTaskDelayUntil(&lastWake, pdMS_TO_TICKS(IMU_PERIOD_MS));
    }
}

// ============================================================
// Task 2: BMP task
// Purpose:
//   Read BMP280 at 50 Hz.
// ============================================================
void taskBmp(void* parameter)
{
    GY91_BMPData localBmp;
    TickType_t lastWake = xTaskGetTickCount();

    while (true) {
        uint32_t startUs = micros();
        recordSharedJitter(&SharedSensorData::bmpJitter, startUs);

        bool ok = false;
        if (xSemaphoreTake(g_spiMutex, pdMS_TO_TICKS(5)) == pdTRUE) {
            ok = bmp.readAll(localBmp, SEA_LEVEL_HPA);
            xSemaphoreGive(g_spiMutex);
        }

        if (ok) {
            updateSharedBmp(localBmp);
        }

        vTaskDelayUntil(&lastWake, pdMS_TO_TICKS(BMP_PERIOD_MS));
    }
}

// ============================================================
// Task 3: Rate calculation task
// Purpose:
//   Calculate actual measured IMU, MAG, and BMP read rates once
//   per second from counters. Also finalizes task jitter reports.
// ============================================================
void taskRate(void* parameter)
{
    TickType_t lastWake = xTaskGetTickCount();

    while (true) {
        vTaskDelayUntil(&lastWake, pdMS_TO_TICKS(RATE_PERIOD_MS));

        uint32_t startUs = micros();

        if (xSemaphoreTake(g_dataMutex, pdMS_TO_TICKS(10)) == pdTRUE) {
            recordJitter(g_data.rateJitter, startUs);

            g_data.imuHz = (float)g_data.imuReadCount;
            g_data.bmpHz = (float)g_data.bmpReadCount;
            g_data.magHz = (float)g_data.magNewCount;

            g_data.imuReadCount = 0;
            g_data.bmpReadCount = 0;
            g_data.magNewCount = 0;

            finalizeJitterStats(g_data.imuJitter);
            finalizeJitterStats(g_data.bmpJitter);
            finalizeJitterStats(g_data.telemetryJitter);
            finalizeJitterStats(g_data.rateJitter);

            xSemaphoreGive(g_dataMutex);
        }
    }
}

// ============================================================
// Task 4: Telemetry task
// Purpose:
//   Print a snapshot at 10 Hz.
//
// Important:
//   This task copies the shared data quickly, releases the mutex,
//   and then prints. Never hold a mutex during Serial.printf().
// ============================================================
void taskTelemetry(void* parameter)
{
    SharedSensorData snapshot;
    TickType_t lastWake = xTaskGetTickCount();

    while (true) {
        vTaskDelayUntil(&lastWake, pdMS_TO_TICKS(TELEMETRY_PERIOD_MS));

        uint32_t startUs = micros();
        recordSharedJitter(&SharedSensorData::telemetryJitter, startUs);

        bool copied = false;
        if (xSemaphoreTake(g_dataMutex, pdMS_TO_TICKS(10)) == pdTRUE) {
            snapshot = g_data;
            copied = true;
            xSemaphoreGive(g_dataMutex);
        }

        if (!copied) {
            Serial.println("[WARN] Telemetry skipped: mutex busy");
            continue;
        }

        Serial.printf(
            "Hz IMU=%7.1f MAG=%5.1f BMP=%5.1f | "
            "ACC[g] %+7.3f %+7.3f %+7.3f | "
            "GYRO[dps] %+8.2f %+8.2f %+8.2f | "
            "MAG[uT] %+7.1f %+7.1f %+7.1f valid=%d | "
            "MPU_T=%6.2fC | "
            "BMP_T=%6.2fC P=%8.2fhPa ALT=%7.2fm\n",

            snapshot.imuHz,
            snapshot.magHz,
            snapshot.bmpHz,

            snapshot.imu.ax_g,
            snapshot.imu.ay_g,
            snapshot.imu.az_g,

            snapshot.imu.gx_dps,
            snapshot.imu.gy_dps,
            snapshot.imu.gz_dps,

            snapshot.imu.mx_uT,
            snapshot.imu.my_uT,
            snapshot.imu.mz_uT,
            snapshot.imu.magValid ? 1 : 0,

            snapshot.imu.temp_c,

            snapshot.bmp.temperature_c,
            snapshot.bmp.pressure_hpa,
            snapshot.bmp.altitude_m
        );

        Serial.printf(
            "JIT[us] "
            "IMU avgDt=%7.1f minDt=%5lu maxDt=%5lu avgJ=%6.1f maxJ=%5lu n=%5lu | "
            "BMP avgDt=%7.1f minDt=%5lu maxDt=%5lu avgJ=%6.1f maxJ=%5lu n=%4lu | "
            "TEL avgDt=%7.1f minDt=%5lu maxDt=%5lu avgJ=%6.1f maxJ=%5lu n=%4lu | "
            "RATE avgDt=%8.1f maxJ=%5lu n=%3lu\n",

            snapshot.imuJitter.report_avg_dt_us,
            (unsigned long)snapshot.imuJitter.report_min_dt_us,
            (unsigned long)snapshot.imuJitter.report_max_dt_us,
            snapshot.imuJitter.report_avg_abs_jitter_us,
            (unsigned long)snapshot.imuJitter.report_max_abs_jitter_us,
            (unsigned long)snapshot.imuJitter.report_samples,

            snapshot.bmpJitter.report_avg_dt_us,
            (unsigned long)snapshot.bmpJitter.report_min_dt_us,
            (unsigned long)snapshot.bmpJitter.report_max_dt_us,
            snapshot.bmpJitter.report_avg_abs_jitter_us,
            (unsigned long)snapshot.bmpJitter.report_max_abs_jitter_us,
            (unsigned long)snapshot.bmpJitter.report_samples,

            snapshot.telemetryJitter.report_avg_dt_us,
            (unsigned long)snapshot.telemetryJitter.report_min_dt_us,
            (unsigned long)snapshot.telemetryJitter.report_max_dt_us,
            snapshot.telemetryJitter.report_avg_abs_jitter_us,
            (unsigned long)snapshot.telemetryJitter.report_max_abs_jitter_us,
            (unsigned long)snapshot.telemetryJitter.report_samples,

            snapshot.rateJitter.report_avg_dt_us,
            (unsigned long)snapshot.rateJitter.report_max_abs_jitter_us,
            (unsigned long)snapshot.rateJitter.report_samples
        );
    }
}

// ============================================================
// Setup
// ============================================================
void setup()
{
    Serial.begin(921600);
    delay(1000);

    Serial.println();
    Serial.println("==============================================");
    Serial.println("GY-91 FreeRTOS All Sensor Reader + Jitter Stats");
    Serial.println("Using existing GY91_MPU9250 and GY91_BMP280 libs");
    Serial.println("==============================================");

    memset(&g_data, 0, sizeof(g_data));
    initJitterStats(g_data.imuJitter, IMU_EXPECTED_US);
    initJitterStats(g_data.bmpJitter, BMP_EXPECTED_US);
    initJitterStats(g_data.telemetryJitter, TELEMETRY_EXPECTED_US);
    initJitterStats(g_data.rateJitter, RATE_EXPECTED_US);

    g_dataMutex = xSemaphoreCreateMutex();
    if (g_dataMutex == nullptr) {
        Serial.println("[FATAL] Failed to create data mutex.");
        while (true) delay(1000);
    }

    g_spiMutex = xSemaphoreCreateMutex();
    if (g_spiMutex == nullptr) {
        Serial.println("[FATAL] Failed to create SPI mutex.");
        while (true) delay(1000);
    }

    pinMode(PIN_MPU_CS, OUTPUT);
    pinMode(PIN_BMP_CS, OUTPUT);
    pinMode(PIN_MPU_INT, INPUT);

    digitalWrite(PIN_MPU_CS, HIGH);
    digitalWrite(PIN_BMP_CS, HIGH);

    SPI.begin(PIN_SPI_SCK, PIN_SPI_MISO, PIN_SPI_MOSI);

    Serial.println("[BOOT] Starting MPU-9250...");
    if (!imu.begin()) {
        Serial.printf("[ERROR] MPU-9250 not detected. WHO_AM_I=0x%02X\n", imu.whoAmI());
        Serial.println("        Check VCC=3V, GND, SCK, MOSI, MISO, NCS/CS.");
        while (true) delay(500);
    }

    Serial.printf("[OK] MPU detected. WHO_AM_I=0x%02X\n", imu.whoAmI());
    Serial.printf("[INFO] AK8963 magnetometer: %s\n", imu.isMagConnected() ? "detected" : "not detected");
    Serial.printf("[INFO] Mag ASA: X=%.4f Y=%.4f Z=%.4f\n", imu.magAsaX, imu.magAsaY, imu.magAsaZ);

    Serial.println("[BOOT] Starting BMP280...");
    if (!bmp.begin()) {
        Serial.printf("[ERROR] BMP280 not detected. CHIP_ID=0x%02X\n", bmp.chipID());
        Serial.println("        Check BMP CSB wiring. If your GY-91 board is I2C-only for BMP, this SPI code will not see it.");
        while (true) delay(500);
    }

    Serial.printf("[OK] BMP280 detected. CHIP_ID=0x%02X\n", bmp.chipID());

    // --------------------------------------------------------
    // Task creation order:
    //   Create lower-priority tasks first.
    //   Create IMU last so it does not starve setup() before the
    //   telemetry/rate tasks are created.
    // --------------------------------------------------------

    xTaskCreatePinnedToCore(
        taskRate,
        "taskRate",
        4096,
        nullptr,
        1,
        &taskRateHandle,
        0
    );

    xTaskCreatePinnedToCore(
        taskTelemetry,
        "taskTelemetry",
        6144,
        nullptr,
        1,
        &taskTelemetryHandle,
        0
    );

    xTaskCreatePinnedToCore(
        taskBmp,
        "taskBmp",
        4096,
        nullptr,
        1,
        &taskBmpHandle,
        1
    );

    xTaskCreatePinnedToCore(
        taskImu,
        "taskImu",
        4096,
        nullptr,
        2,
        &taskImuHandle,
        1
    );

    Serial.println("[BOOT] FreeRTOS tasks started.");
    Serial.println();
}

// ============================================================
// Loop
// ============================================================
void loop()
{
    // Nothing here. All work is done in FreeRTOS tasks.
    vTaskDelay(pdMS_TO_TICKS(1000));
}
